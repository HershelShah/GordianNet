# Doxyfile for GordianNet
# Generate with: doxygen Doxyfile

#---------------------------------------------------------------------------
# Project
#---------------------------------------------------------------------------
PROJECT_NAME           = "GordianNet"
PROJECT_NUMBER         = "0.1.0"
PROJECT_BRIEF          = "Lightweight bare-metal P2P link-layer library"
PROJECT_LOGO           =

OUTPUT_DIRECTORY       = docs/doxygen
CREATE_SUBDIRS         = NO

#---------------------------------------------------------------------------
# Input
#---------------------------------------------------------------------------
INPUT                  = include/gordian_net.h \
                         src/gordian_node.hpp \
                         src/gordian_node.cpp \
                         cli/main.cpp \
                         docs/ARCHITECTURE.md \
                         docs/SECURITY.md
FILE_PATTERNS          = *.h *.hpp *.cpp *.md
RECURSIVE              = NO

# Treat .md files as documentation pages
USE_MDFILE_AS_MAINPAGE = docs/ARCHITECTURE.md

#---------------------------------------------------------------------------
# Extraction
#---------------------------------------------------------------------------
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = YES
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES

# Show internal (non-public) documentation
INTERNAL_DOCS          = YES

# Include source code in documentation
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = NO
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

#---------------------------------------------------------------------------
# Build
#---------------------------------------------------------------------------
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
BRIEF_MEMBER_DESC      = YES
REPEAT_BRIEF           = YES
ALWAYS_DETAILED_SEC    = NO
FULL_PATH_NAMES        = NO
JAVADOC_AUTOBRIEF      = YES
MULTILINE_CPP_IS_BRIEF = NO
TAB_SIZE               = 4
OPTIMIZE_OUTPUT_FOR_C  = NO
MARKDOWN_SUPPORT       = YES

#---------------------------------------------------------------------------
# Warnings
#---------------------------------------------------------------------------
QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO

#---------------------------------------------------------------------------
# HTML output
#---------------------------------------------------------------------------
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_COLORSTYLE        = LIGHT
HTML_DYNAMIC_SECTIONS  = YES
HTML_TIMESTAMP         = YES
SEARCHENGINE           = YES

# Mermaid support via CDN (Doxygen 1.9.7+)
HTML_EXTRA_STYLESHEET  =
HTML_EXTRA_FILES       =

#---------------------------------------------------------------------------
# Diagrams
#---------------------------------------------------------------------------
HAVE_DOT               = NO
CLASS_DIAGRAMS         = YES
COLLABORATION_GRAPH    = NO
INCLUDE_GRAPH          = YES
INCLUDED_BY_GRAPH      = YES
CALL_GRAPH             = NO
CALLER_GRAPH           = NO

#---------------------------------------------------------------------------
# LaTeX output (disabled by default)
#---------------------------------------------------------------------------
GENERATE_LATEX         = NO

#---------------------------------------------------------------------------
# Other output formats (disabled)
#---------------------------------------------------------------------------
GENERATE_MAN           = NO
GENERATE_RTF           = NO
GENERATE_XML           = NO

#---------------------------------------------------------------------------
# Preprocessor
#---------------------------------------------------------------------------
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
PREDEFINED             = GORDIAN_NET_BUILDING \
                         GORDIAN_API=
EXPAND_ONLY_PREDEF     = NO
